{
  "name": "bia_ops",
  "private": true,
  "version": "2.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --port 8080",
    "staging": "vite build --mode staging",
    "build": "tsc && vite build --mode production",
    "preview": "vite preview",
    "test.e2e": "cypress run",
    "test.unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "prettier": "prettier --check .",
    "prepare": "husky install",
    "commit": "git-cz",
    "capacitor:add": "npx cap add",
    "capacitor:copy": "npx cap copy",
    "capacitor:sync": "npx cap sync",
    "capacitor:update": "npx cap update",
    "build:ios": "npm run build && npx cap copy ios && npx cap open ios",
    "build:android": "npm run build && npx cap copy android && npx cap open android",
    "dev:ios": "CAPACITOR_PLATFORM=ios npm run dev",
    "dev:android": "CAPACITOR_PLATFORM=android npm run dev",
    "mobile:setup": "npx cap add ios && npx cap add android",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:run:ios": "npm run mobile:build && npx cap run ios",
    "mobile:run:android": "npm run mobile:build && npx cap run android",
    "ionic:build": "npm run build",
    "ionic:serve": "npm run dev"
  },
  "lint-staged": {
    "*.ts?(x)": [
      "npx tsc --noEmit",
      "npx eslint --fix",
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "7.4.2",
    "@capacitor/app": "7.0.2",
    "@capacitor/cli": "7.4.2",
    "@capacitor/core": "7.4.2",
    "@capacitor/device": "7.0.2",
    "@capacitor/haptics": "7.0.2",
    "@capacitor/ios": "7.4.2",
    "@capacitor/keyboard": "7.0.2",
    "@capacitor/local-notifications": "^7.0.2",
    "@capacitor/network": "7.0.2",
    "@capacitor/preferences": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.2",
    "@capacitor/splash-screen": "7.0.2",
    "@capacitor/status-bar": "7.0.2",
    "@fortawesome/fontawesome-pro": "7.0.0",
    "@fortawesome/fontawesome-svg-core": "7.0.0",
    "@fortawesome/pro-regular-svg-icons": "7.0.0",
    "@fortawesome/pro-solid-svg-icons": "7.0.0",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@ionic/react": "8.7.10",
    "@ionic/react-router": "8.7.10",
    "@tanstack/react-query": "^5.55.4",
    "@tanstack/react-query-devtools": "^5.55.4",
    "@tanstack/react-table": "^8.21.3",
    "@types/js-cookie": "^3.0.6",
    "@types/mixpanel-browser": "^2.51.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "dexie": "^4.0.10",
    "firebase": "12.0.0",
    "i18next": "25.3.2",
    "ionicons": "8.0.13",
    "js-cookie": "^3.0.5",
    "mixpanel-browser": "^2.59.0",
    "quagga": "^0.12.1",
    "react": "^18.2.0",
    "react-day-picker": "^8.8.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.53.0",
    "react-i18next": "^15.0.1",
    "react-pdf": "10.0.1",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "react-signature-canvas": "^1.0.6",
    "react-toastify": "^11.0.3",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/dexie": "^1.3.32",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@types/react-signature-canvas": "^1.0.6",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "@vitejs/plugin-legacy": "7.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "14.5.3",
    "depcheck": "^1.4.7",
    "eslint": "9.32.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "^7.35.2",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "git-cz": "^4.9.0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "16.1.4",
    "prettier": "^3.3.3",
    "terser": "^5.4.0",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.39.0",
    "unimported": "^1.31.0",
    "vite": "7.0.6",
    "vite-plugin-pwa": "1.0.2",
    "vitest": "3.2.4"
  }
}
